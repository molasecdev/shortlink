---
import MainLayout from '../layouts/MainLayout.astro';
import { validateSession } from '../lib/session';
import { getUserById } from '../lib/auth';
import { getAllLinks, getLinksByUser } from '../lib/links';
import { getAllUsers } from '../lib/auth';
import { formatDateToDDMMYYYY } from '../lib/date';

const cookies = Astro.request.headers.get('cookie');
const sessionId = cookies?.split('; ').find(c => c.startsWith('session='))?.split('=')[1];

if (!sessionId) {
  return Astro.redirect('/login');
}

const userId = await validateSession(sessionId);
if (!userId) {
  return Astro.redirect('/login');
}

const user = await getUserById(userId);
if (!user) {
  return Astro.redirect('/login');
}

const allLinks = await getAllLinks();
const userLinks = await getLinksByUser(user.id);
const totalClicks = allLinks.reduce((sum, link) => sum + link.clicks, 0);
const userTotalClicks = userLinks.reduce((sum, link) => sum + link.clicks, 0);

let allUsers = [];
let topLinks = [];
let recentLinks = [];
const maxData = 10;

if (user.role === 'admin') {
  allUsers = await getAllUsers();
  topLinks = allLinks.sort((a, b) => b.clicks - a.clicks).slice(0, maxData);
  recentLinks = allLinks.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()).slice(0, 5);
} else {
  topLinks = userLinks.sort((a, b) => b.clicks - a.clicks).slice(0, maxData);
  recentLinks = userLinks.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()).slice(0, 5);
}

const createdBy = (createdBy) => {
	return createdBy 
	? allUsers.find((u) => u.id === createdBy)?.username 
	: "Unknown";
}
---

<MainLayout title="Dashboard" user={{ id: user.id, username: user.username, role: user.role }}>
  {user.role === 'admin' ? (
    <div>
      <h1 class="text-3xl font-bold mb-8">Admin Dashboard</h1>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">Total Users</p>
          <p class="text-3xl font-bold text-blue-600">{allUsers.length}</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">Total Links</p>
          <p class="text-3xl font-bold text-green-600">{allLinks.length}</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">Total Clicks</p>
          <p class="text-3xl font-bold text-purple-600">{totalClicks}</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">Avg Clicks/Link</p>
          <p class="text-3xl font-bold text-orange-600">{allLinks.length > 0 ? Math.round(totalClicks / allLinks.length) : 0}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-lg shadow">
          <h2 class="text-xl font-bold mb-4">Top 10 Links</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-100">
                <tr>
                  <th class="px-4 py-2 text-left">Slug</th>
                  <th class="px-4 py-2 text-left">Clicks</th>
                  <th class="px-4 py-2 text-left">Owner</th>
                </tr>
              </thead>
              <tbody>
                {topLinks.map(link => (
                  <tr class="border-t hover:bg-gray-50">
                    <td class="px-4 py-2">
                      <a href={`/links`} class="text-blue-600 hover:underline">{link.slug}</a>
                    </td>
                    <td class="px-4 py-2">{link.clicks}</td>
                    <td class="px-4 py-2">{createdBy(link.createdBy)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <h2 class="text-xl font-bold mb-4">Recent Links</h2>
          <div class="space-y-3">
            {recentLinks.map(link => (
              <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
                <div>
                  <p class="font-medium">{link.slug}</p>
                  <p class="text-xs text-gray-500">{formatDateToDDMMYYYY(link.createdAt)}</p>
                </div>
                <span class="text-sm text-gray-600">{link.clicks} clicks</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div>
      <h1 class="text-3xl font-bold mb-8">My Dashboard</h1>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">My Links</p>
          <p class="text-3xl font-bold text-blue-600">{userLinks.length}</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">Total Clicks</p>
          <p class="text-3xl font-bold text-green-600">{userTotalClicks}</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
          <p class="text-gray-600 text-sm">Avg Clicks/Link</p>
          <p class="text-3xl font-bold text-purple-600">{userLinks.length > 0 ? Math.round(userTotalClicks / userLinks.length) : 0}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-lg shadow">
          <h2 class="text-xl font-bold mb-4">Top Links</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-100">
                <tr>
                  <th class="px-4 py-2 text-left">Slug</th>
                  <th class="px-4 py-2 text-left">Clicks</th>
                </tr>
              </thead>
              <tbody>
                {topLinks.map(link => (
                  <tr class="border-t hover:bg-gray-50">
                    <td class="px-4 py-2">
                      <a href={`/links/edit/${link.id}`} class="text-blue-600 hover:underline">{link.slug}</a>
                    </td>
                    <td class="px-4 py-2">{link.clicks}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <h2 class="text-xl font-bold mb-4">Recent Links</h2>
          <div class="space-y-3">
            {recentLinks.map(link => (
              <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
                <div>
                  <p class="font-medium">{link.slug}</p>
                  <p class="text-xs text-gray-500">{formatDateToDDMMYYYY(link.createdAt)}</p>
                </div>
                <span class="text-sm text-gray-600">{link.clicks} clicks</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}
</MainLayout>
