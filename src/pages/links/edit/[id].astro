---
import MainLayout from "../../../layouts/MainLayout.astro";
import { validateSession } from "../../../lib/session";
import { getUserById } from "../../../lib/auth";
import { getLinkById, updateLink, deleteLink } from "../../../lib/links";
import { info, cekEnv } from "../../../../constants";

const cookies = Astro.request.headers.get("cookie");
const sessionId = cookies
	?.split("; ")
	.find((c) => c.startsWith("session="))
	?.split("=")[1];

if (!sessionId) {
	return Astro.redirect("/login");
}

const userId = await validateSession(sessionId);
if (!userId) {
	return Astro.redirect("/login");
}

const user = await getUserById(userId);
if (!user) {
	return Astro.redirect("/login");
}

const { id } = Astro.params;
const link = await getLinkById(id as string);

if (!link) {
	return Astro.redirect("/links");
}

// Check authorization
if (user.role !== "admin" && link.createdBy !== user.id) {
	return Astro.redirect("/links");
}

const shortUrl = cekEnv(link.slug);

let error = "";
let success = "";
---

<MainLayout
	title="Edit Link"
	user={{ id: user.id, username: user.username, role: user.role }}
>
	<div class="max-w-2xl mx-auto bg-white rounded-lg shadow p-8">
		<h1 class="text-2xl font-bold mb-6">Edit Short Link</h1>

		{
			error && (
				<div class="bg-red-100 text-red-800 p-3 rounded mb-4">{error}</div>
			)
		}
		{
			success && (
				<div class="bg-green-100 text-green-800 p-3 rounded mb-4">
					{success}
				</div>
			)
		}

		<div class="bg-gray-50 p-4 rounded mb-6">
			<p class="text-sm text-gray-600">
				Short URL: 
        <a class="font-mono font-bold hover:text-blue-600" href={shortUrl} target="_blank" rel="noopener noreferrer">
          {shortUrl}
        </a>
			</p>
			<p class="text-sm text-gray-600 mt-2">
				Total Clicks: <span class="font-bold">{link.clicks}</span>
			</p>
		</div>

		<form method="POST" action={`/api/links/${link.id}`} class="space-y-4 mb-6">
			<input type="hidden" name="action" value="update" />

			<div>
				<label for="slug" class="block text-sm font-medium text-gray-700 mb-1"
					>Slug (Short Code)</label
				>
				<input
					type="text"
					id="slug"
					name="slug"
					value={link.slug}
					minlength="3"
					maxlength="50"
					pattern="[a-zA-Z0-9_-]+"
					required
				/>
			</div>

			<div>
				<label
					for="targetUrl"
					class="block text-sm font-medium text-gray-700 mb-1">Target URL</label
				>
				<input
					type="url"
					id="targetUrl"
					name="targetUrl"
					value={link.targetUrl}
					required
				/>
			</div>

			<div class="flex gap-2">
				<button type="submit" class="btn-primary">Save Changes</button>
				<button class="btn-secondary">
					<a href="/links">Cancel</a>
				</button>
			</div>
		</form>

		<hr class="my-6" />

		<div class="bg-red-50 p-4 rounded">
			<h3 class="text-red-900 font-bold mb-2">Danger Zone</h3>
			<p class="text-sm text-red-800 mb-3">
				Deleting this link will remove it permanently.
			</p>
			<form id="deleteForm" method="POST" action={`/api/links/${link.id}`}>
				<input type="hidden" name="action" value="delete" />
				<button
					type="button"
					id="openDeleteModal"
					class="btn-danger"
					>Delete Link</button
			</form>

			<!-- Delete confirmation modal -->
			<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center">
				<div class="absolute inset-0 bg-black/50"></div>
				<div class="relative bg-white rounded-lg shadow-lg max-w-md w-full mx-4 p-6">
					<h3 class="text-lg font-semibold text-red-900 mb-2">Confirm Delete</h3>
					<p class="text-sm text-gray-700 mb-4">Are you sure you want to permanently delete this link? This action cannot be undone.</p>
					<div class="flex justify-end gap-2">
						<button id="cancelDelete" class="btn-secondary">Cancel</button>
						<button id="confirmDelete" class="btn-danger">Yes, delete</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</MainLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
	const openBtn = document.getElementById('openDeleteModal');
	const modal = document.getElementById('deleteModal');
	const cancelBtn = document.getElementById('cancelDelete');
	const confirmBtn = document.getElementById('confirmDelete');
	const form = document.getElementById('deleteForm');

	if (!openBtn || !modal || !cancelBtn || !confirmBtn || !form) return;

	function showModal() {
		modal.classList.remove('hidden');
		modal.classList.add('flex');
	}

	function hideModal() {
		modal.classList.remove('flex');
		modal.classList.add('hidden');
	}

	openBtn.addEventListener('click', (e) => {
		e.preventDefault();
		showModal();
	});

	cancelBtn.addEventListener('click', (e) => {
		e.preventDefault();
		hideModal();
	});

	confirmBtn.addEventListener('click', (e) => {
		e.preventDefault();
		// submit the form to perform server-side delete
		form.submit();
	});
});
</script>
