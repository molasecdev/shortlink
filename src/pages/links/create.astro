---
import MainLayout from "../../layouts/MainLayout.astro";
import { validateSession } from "../../lib/session";
import { getUserById } from "../../lib/auth";
import { createLink } from "../../lib/links";

const cookies = Astro.request.headers.get("cookie");
const sessionId = cookies
	?.split("; ")
	.find((c) => c.startsWith("session="))
	?.split("=")[1];

if (!sessionId) {
	return Astro.redirect("/login");
}

const userId = await validateSession(sessionId);
if (!userId) {
	return Astro.redirect("/login");
}

const user = await getUserById(userId);
if (!user) {
	return Astro.redirect("/login");
}

let error = "";
---

<MainLayout
	title="Create Link"
	user={{ id: user.id, username: user.username, role: user.role }}
>
	<div class="max-w-2xl mx-auto bg-white rounded-lg shadow p-8">
		<h1 class="text-2xl font-bold mb-6">Create New Short Link</h1>

		{
			error && (
				<div class="bg-red-100 text-red-800 p-3 rounded mb-4">{error}</div>
			)
		}

		<form method="POST" action="/api/links/create" class="space-y-4">
			<div>
				<label for="slug" class="block text-sm font-medium text-gray-700 mb-1"
					>Slug (Short Code)</label
				>
				<input
					type="text"
					id="slug"
					name="slug"
					placeholder="e.g., promo"
					minlength="3"
					maxlength="50"
					pattern="[a-zA-Z0-9_-]+"
					required
				/>
				<p class="text-xs text-gray-500 mt-1">
					3-50 characters, only letters, numbers, dash, and underscore
				</p>
			</div>

			<div>
				<label
					for="targetUrl"
					class="block text-sm font-medium text-gray-700 mb-1">Target URL</label
				>
				<input
					type="text"
					id="targetUrl"
					name="targetUrl"
					placeholder="https://example.com/promo"
					required
				/>
				<p class="text-xs text-gray-500 mt-1">Must be a valid URL</p>
			</div>

			<div class="flex gap-2">
				<button type="submit" class="btn-primary">Create Link</button>
				<button class="btn-danger">
					<a href="/links">Cancel</a>
				</button>
			</div>
		</form>
	</div>
</MainLayout>
