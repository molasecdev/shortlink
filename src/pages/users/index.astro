---
import MainLayout from '../../layouts/MainLayout.astro';
import { validateSession } from '../../lib/session';
import { getUserById, getAllUsers } from '../../lib/auth';
import { formatDateToDDMMYYYY } from '../../lib/date';

const cookies = Astro.request.headers.get('cookie');
const sessionId = cookies?.split('; ').find(c => c.startsWith('session='))?.split('=')[1];

if (!sessionId) {
  return Astro.redirect('/login');
}

const userId = await validateSession(sessionId);
if (!userId) {
  return Astro.redirect('/login');
}

const user = await getUserById(userId);
if (!user) {
  return Astro.redirect('/login');
}

// Admin only
if (user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const users = await getAllUsers();
const searchQuery = Astro.url.searchParams.get('search') || '';
let filteredUsers = users;

if (searchQuery) {
  filteredUsers = users.filter(u => u.username.includes(searchQuery));
}

filteredUsers = filteredUsers.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
---

<MainLayout title="Users" user={{ id: user.id, username: user.username, role: user.role }}>
  <div>
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold">User Management</h1>
      <button class="btn-primary">
        <a href="/users/create">Create User</a>
      </button>
    </div>

    <div class="bg-white p-4 rounded-lg shadow mb-6">
      <form method="GET" class="flex gap-2">
        <input
          type="text"
          name="search"
          placeholder="Search by username..."
          value={searchQuery}
          class="flex-1"
        />
        <button type="submit" class="btn-primary">Search</button>
        {searchQuery && (
          <button class="btn-secondary">
            <a href="/users">Clear</a>
          </button>
        )}
      </form>
    </div>

    {filteredUsers.length === 0 ? (
      <div class="bg-yellow-50 p-4 rounded-lg border border-yellow-200">
        <p class="text-yellow-800">No users found.</p>
      </div>
    ) : (
      <div class="bg-white rounded-lg shadow overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-100 border-b">
            <tr>
              <th class="px-6 py-3 text-left text-sm font-medium text-gray-700">Username</th>
              <th class="px-6 py-3 text-left text-sm font-medium text-gray-700">Role</th>
              <th class="px-6 py-3 text-left text-sm font-medium text-gray-700">Created</th>
              <th class="px-6 py-3 text-left text-sm font-medium text-gray-700">Actions</th>
            </tr>
          </thead>
          <tbody>
            {filteredUsers.map(u => (
              <tr class="border-b hover:bg-gray-50">
                <td class="px-6 py-3 text-sm font-medium">{u.username}</td>
                <td class="px-6 py-3 text-sm">
                  <span class={u.role === 'admin' ? 'bg-red-100 text-red-800 px-2 py-1 rounded text-xs' : 'bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs'}>
                    {u.role}
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-gray-600">{formatDateToDDMMYYYY(u.createdAt)}</td>
                <td class="px-6 py-3 text-sm flex gap-2">
                  <button class="btn-info btn-sm">
                    <a href={`/users/edit/${u.id}`}>Edit</a>
                  </button>
                  <button class="btn-important btn-sm">
                    <a href={`/links?user=${u.id}`}>View URLs</a>
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</MainLayout>
