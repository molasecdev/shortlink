---
import MainLayout from '../../layouts/MainLayout.astro';
import { validateSession } from '../../lib/session';
import { getUserById } from '../../lib/auth';

const cookies = Astro.request.headers.get('cookie');
const sessionId = cookies?.split('; ').find(c => c.startsWith('session='))?.split('=')[1];

if (!sessionId) {
  return Astro.redirect('/login');
}

const userId = await validateSession(sessionId);
if (!userId) {
  return Astro.redirect('/login');
}

const user = await getUserById(userId);
if (!user) {
  return Astro.redirect('/login');
}

// Admin only
if (user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

let error = '';
---

<MainLayout title="Create User" user={{ id: user.id, username: user.username, role: user.role }}>
  <div class="max-w-2xl mx-auto bg-white rounded-lg shadow p-8">
    <h1 class="text-2xl font-bold mb-6">Create New User</h1>

    {error && <div class="bg-red-100 text-red-800 p-3 rounded mb-4">{error}</div>}

    <form method="POST" action="/api/users/create" class="space-y-4">
      <div>
        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          minlength="4"
          maxlength="30"
          required
        />
        <p class="text-xs text-gray-500 mt-1">4-30 characters</p>
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          minlength="8"
          required
        />
        <p class="text-xs text-gray-500 mt-1">Minimum 8 characters</p>
      </div>

      <div>
        <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role</label>
        <select id="role" name="role" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
          <option value="user">User</option>
          <option value="admin">Admin</option>
        </select>
      </div>

      <div class="flex gap-2">
        <button type="submit" class="btn-primary">Create User</button>
        <a href="/users" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</MainLayout>
