---
import MainLayout from '../../layouts/MainLayout.astro';
import { validateSession } from '../../lib/session';
import { getUserById } from '../../lib/auth';

const cookies = Astro.request.headers.get('cookie');
const sessionId = cookies?.split('; ').find(c => c.startsWith('session='))?.split('=')[1];

if (!sessionId) {
  return Astro.redirect('/login');
}

const userId = await validateSession(sessionId);
if (!userId) {
  return Astro.redirect('/login');
}

const user = await getUserById(userId);
if (!user) {
  return Astro.redirect('/login');
}

// Admin only
if (user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const username = formData.get('username') as string;
  const password = formData.get('password') as string;
  const role = formData.get('role') as 'admin' | 'user';

  if (!username || !password) {
    error = 'Username and password are required';
  } else if (username.length < 4 || username.length > 30) {
    error = 'Username must be between 4 and 30 characters';
  } else if (password.length < 8) {
    error = 'Password must be at least 8 characters';
  } else {
    try {
      const response = await Astro.callEndpoint(
        new URL('/api/users/create', Astro.url.origin).toString(),
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Cookie': `session=${sessionId}`
          },
          body: JSON.stringify({ username, password, role: role || 'user' }),
        }
      );

      if (response.ok) {
        return Astro.redirect('/users');
      } else {
        const data = await response.json() as { error?: string };
        error = data.error || 'Failed to create user';
      }
    } catch {
      error = 'An error occurred. Please try again.';
    }
  }
}
---

<MainLayout title="Create User" user={{ id: user.id, username: user.username, role: user.role }}>
  <div class="max-w-2xl mx-auto bg-white rounded-lg shadow p-8">
    <h1 class="text-2xl font-bold mb-6">Create New User</h1>

    {error && <div class="bg-red-100 text-red-800 p-3 rounded mb-4">{error}</div>}

    <form method="POST" class="space-y-4">
      <div>
        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          minlength="4"
          maxlength="30"
          required
        />
        <p class="text-xs text-gray-500 mt-1">4-30 characters</p>
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          minlength="8"
          required
        />
        <p class="text-xs text-gray-500 mt-1">Minimum 8 characters</p>
      </div>

      <div>
        <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role</label>
        <select id="role" name="role" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
          <option value="user">User</option>
          <option value="admin">Admin</option>
        </select>
      </div>

      <div class="flex gap-2">
        <button type="submit" class="btn-primary">Create User</button>
        <a href="/users" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</MainLayout>
