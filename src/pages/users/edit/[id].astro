---
import MainLayout from '../../../layouts/MainLayout.astro';
import { validateSession } from '../../../lib/session';
import { getUserById, updateUser, deleteUser, hashPassword } from '../../../lib/auth';

const cookies = Astro.request.headers.get('cookie');
const sessionId = cookies?.split('; ').find(c => c.startsWith('session='))?.split('=')[1];

if (!sessionId) {
  return Astro.redirect('/login');
}

const userId = await validateSession(sessionId);
if (!userId) {
  return Astro.redirect('/login');
}

const currentUser = await getUserById(userId);
if (!currentUser) {
  return Astro.redirect('/login');
}

// Admin only
if (currentUser.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const { id } = Astro.params;
const editUser = await getUserById(id as string);

if (!editUser) {
  return Astro.redirect('/users');
}

let error = '';
let success = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;

  if (action === 'delete') {
    try {
      await deleteUser(editUser.id);
      return Astro.redirect('/users');
    } catch (err) {
      console.error('Delete user error:', err);
      error = err instanceof Error ? err.message : 'Failed to delete user';
    }
  } else {
    const username = formData.get('username') as string;
    const role = formData.get('role') as 'admin' | 'user';
    const password = formData.get('password') as string;

    if (!username) {
      error = 'Username is required';
    } else if (username.length < 4 || username.length > 30) {
      error = 'Username must be between 4 and 30 characters';
    } else if (password && password.length < 8) {
      error = 'Password must be at least 8 characters';
    } else {
      try {
        const updates: any = { username, role };
        if (password) {
          updates.passwordHash = await hashPassword(password);
        }
        const updated = await updateUser(editUser.id, updates);
        if (updated) {
          return Astro.redirect('/users');
        }
      } catch (err) {
        console.error('Update user error:', err);
        error = err instanceof Error ? err.message : 'An error occurred. Please try again.';
      }
    }
  }
}
---

<MainLayout title="Edit User" user={{ id: currentUser.id, username: currentUser.username, role: currentUser.role }}>
  <div class="max-w-2xl mx-auto bg-white rounded-lg shadow p-8">
    <h1 class="text-2xl font-bold mb-6">Edit User: {editUser.username}</h1>

    {error && <div class="bg-red-100 text-red-800 p-3 rounded mb-4">{error}</div>}
    {success && <div class="bg-green-100 text-green-800 p-3 rounded mb-4">{success}</div>}

    <form method="POST" class="space-y-4 mb-6">
      <input type="hidden" name="action" value="update" />

      <div>
        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          value={editUser.username}
          minlength="4"
          maxlength="30"
          required
        />
      </div>

      <div>
        <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role</label>
        <select id="role" name="role" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
          <option value="user" selected={editUser.role === 'user'}>User</option>
          <option value="admin" selected={editUser.role === 'admin'}>Admin</option>
        </select>
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">New Password (Leave blank to keep current)</label>
        <input
          type="password"
          id="password"
          name="password"
          minlength="8"
        />
      </div>

      <div class="flex gap-2">
        <button type="submit" class="btn-primary">Save Changes</button>
        <button class="btn-secondary">
          <a href="/users">Cancel</a>
        </button>
      </div>
    </form>

    {editUser.id !== currentUser.id && (
      <>
        <hr class="my-6" />

        <div class="bg-red-50 p-4 rounded">
          <h3 class="text-red-900 font-bold mb-2">Danger Zone</h3>
          <p class="text-sm text-red-800 mb-3">Deleting this user will remove it permanently and delete all their links.</p>
          <form id="deleteUserForm" method="POST">
            <input type="hidden" name="action" value="delete" />
            <button type="button" id="openDeleteUserModal" class="btn-danger">Delete User</button>
          </form>

          <!-- Delete user confirmation modal -->
          <div id="deleteUserModal" class="fixed inset-0 z-50 hidden items-center justify-center">
            <div class="absolute inset-0 bg-black/50"></div>
            <div class="relative bg-white rounded-lg shadow-lg max-w-md w-full mx-4 p-6">
              <h3 class="text-lg font-semibold text-red-900 mb-2">Confirm Delete User</h3>
              <p class="text-sm text-gray-700 mb-4">Are you sure you want to permanently delete this user and all their links? This action cannot be undone.</p>
              <div class="flex justify-end gap-2">
                <button id="cancelDeleteUser" class="btn-secondary">Cancel</button>
                <button id="confirmDeleteUser" class="btn-danger">Yes, delete</button>
              </div>
            </div>
          </div>
        </div>
      </>
    )}

    {editUser.id === currentUser.id && (
      <div class="bg-blue-50 p-4 rounded">
        <p class="text-sm text-blue-800">You cannot delete your own account.</p>
      </div>
    )}
  </div>
</MainLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const openBtn = document.getElementById('openDeleteUserModal');
  const modal = document.getElementById('deleteUserModal');
  const cancelBtn = document.getElementById('cancelDeleteUser');
  const confirmBtn = document.getElementById('confirmDeleteUser');
  const form = document.getElementById('deleteUserForm');

  if (!openBtn || !modal || !cancelBtn || !confirmBtn || !form) return;

  function showModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function hideModal() {
    modal.classList.remove('flex');
    modal.classList.add('hidden');
  }

  openBtn.addEventListener('click', (e) => {
    e.preventDefault();
    showModal();
  });

  cancelBtn.addEventListener('click', (e) => {
    e.preventDefault();
    hideModal();
  });

  confirmBtn.addEventListener('click', (e) => {
    e.preventDefault();
    form.submit();
  });
});
</script>
