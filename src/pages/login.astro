---
import MainLayout from "../layouts/MainLayout.astro";
import {
	validateSession,
	createSession,
	setSessionCookie,
} from "../lib/session";
import { getUserByUsername, verifyPassword } from "../lib/auth";

const cookies = Astro.request.headers.get("cookie");
const sessionId = cookies
	?.split("; ")
	.find((c) => c.startsWith("session="))
	?.split("=")[1];

if (sessionId) {
	const userId = await validateSession(sessionId);
	if (userId) {
		return Astro.redirect("/dashboard");
	}
}

let error = "";

if (Astro.request.method === "POST") {
		// Temporary logging to help debug 403 on production deployments
		try {
			const headersObj = {
				host: Astro.request.headers.get('host'),
				origin: Astro.request.headers.get('origin'),
				referer: Astro.request.headers.get('referer'),
				'x-forwarded-for': Astro.request.headers.get('x-forwarded-for') || Astro.request.headers.get('x-real-ip')
			};
			console.log('Login POST received', headersObj);
		} catch (e) {
			console.log('Login logging error', e);
		}
	const formData = await Astro.request.formData();
	const username = formData.get("username") as string;
	const password = formData.get("password") as string;

	if (!username || !password) {
		error = "Username and password are required";
	} else {
		try {
			const user = await getUserByUsername(username);
			if (!user) {
				error = "Invalid username or password";
			} else {
				const valid = await verifyPassword(password, user.passwordHash);
				if (!valid) {
					error = "Invalid username or password";
				} else {
					const sessionId = await createSession(user.id);
					const headers = new Headers();
					setSessionCookie(headers, sessionId);
					headers.set("Location", "/dashboard");
					return new Response(null, { status: 302, headers });
				}
			}
		} catch (err) {
			console.error("Login error:", err);
			error = "An error occurred. Please try again.";
		}
	}
}
---

<MainLayout title="Login">
	<div class="max-w-md mx-auto bg-white rounded-lg shadow p-8">
		<h1 class="text-2xl font-bold mb-6">Login</h1>

		{
			error && (
				<div class="bg-red-100 text-red-800 p-3 rounded mb-4">{error}</div>
			)
		}

		<form method="POST">
			<div class="mb-4">
				<label
					for="username"
					class="block text-sm font-medium text-gray-700 mb-1">Username</label
				>
        <input type="text" id="username" name="username" minlength="4" maxlength="30" class="w-full" required />
			</div>

			<div class="mb-6">
				<label
					for="password"
					class="block text-sm font-medium text-gray-700 mb-1">Password</label
				>
				<div class="relative">
          <input type="password" id="password" name="password" minlength="8" class="w-full pr-10" required />
          <button
            type="button"
            class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 focus:outline-none"
            id="togglePasswordLogin"
            aria-label="Show password"
            tabindex="-1"
          >
            <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1l22 22"/>
            </svg>
          </button>
				</div>
			</div>

			<button type="submit" class="btn-primary w-full mb-4">Login</button>
		</form>

		<p class="text-center text-sm text-gray-600">
			Don't have an account? <a
				href="/register"
				class="text-blue-600 hover:text-blue-800">Register here</a
			>
		</p>
	</div>
</MainLayout>

<script is:inline>
  const toggleBtn = document.getElementById("togglePasswordLogin");
  const passwordInput = document.getElementById("password");

  const eyeOn = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
  </svg>`;

  const eyeOff = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1l22 22"/>
  </svg>`;

  let visible = true;

  toggleBtn?.addEventListener("click", () => {
    visible = !visible;
    passwordInput.type = visible ? "text" : "password";
    toggleBtn.innerHTML = visible ? eyeOff : eyeOn;
  });
</script>
