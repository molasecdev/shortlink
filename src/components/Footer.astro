---
const startYear = 2026;
const currentYear = new Date().getFullYear();
const yearDisplay = currentYear === startYear ? `${startYear}` : `${startYear}–${currentYear}`;
---

<footer class="bg-white shadow mt-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-center text-sm text-gray-600">
    <p>&copy; {yearDisplay} ShortURL Management System. All rights reserved.</p>
  </div>
</footer>
